# Copy to .env
# IMPORTANT: Generate a secret with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
DATABASE_URL=postgresql+psycopg://srs:srs@db:5432/srs
APP_SESSION_MAX_AGE_SECONDS=3888000
OIDC_STATE_SESSION_MAX_AGE_SECONDS=3888000
SYSTEM_ADMIN_BOOTSTRAP_EMAIL=johndoe@email.com
FOOTER_COPYRIGHT_TEXT=SelViz Software Solutions
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_GENERATION_ENABLED=false
BULK_IMPORT_API_KEY=

# Default question count for tests (0 = disable auto-start, shows modal instead)
DEFAULT_TEST_COUNT=0

# Security (set to true in production with HTTPS)
FORCE_SECURE_COOKIES=true

# Allowed origins for CSRF protection on form POSTs (comma-separated, * for any)
ALLOWED_ORIGINS=*

# Google OIDC
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.comauth/google/callback
GOOGLE_SCOPES=openid email profile

# Microsoft Entra External ID / generic OIDC


# Preferred: set MICROSOFT_ENTRA_EXTERNAL_ID_METADATA_URL to the tenant/app-specific
# OpenID Connect metadata document URL from Azure Entra External ID.
# Example:
#   MICROSOFT_ENTRA_EXTERNAL_ID_METADATA_URL=https://login.microsoftonline.com/<tenant-id>/v2.0/.well-known/openid-configuration
#
# If you do not set metadata_url, the app can fall back to MICROSOFT_ENTRA_EXTERNAL_ID_AUTHORITY.
# Keep AUTHORIZE_AUTHORITY aligned with the same authority family when overriding it.
MICROSOFT_ENTRA_EXTERNAL_ID_AUTHORITY=
MICROSOFT_ENTRA_EXTERNAL_ID_AUTHORIZE_AUTHORITY=
MICROSOFT_ENTRA_EXTERNAL_ID_METADATA_URL=
MICROSOFT_ENTRA_EXTERNAL_ID_TENANT_ID=
MICROSOFT_ENTRA_EXTERNAL_ID_TENANT_DOMAIN=
MICROSOFT_ENTRA_EXTERNAL_ID_CLIENT_ID=
MICROSOFT_ENTRA_EXTERNAL_ID_CLIENT_SECRET=
MICROSOFT_ENTRA_EXTERNAL_ID_REDIRECT_URI=https://your-domain.com/auth/callback
MICROSOFT_ENTRA_EXTERNAL_ID_SCOPES=openid profile email

# Legacy Azure AD B2C compatibility (optional fallback while migrating)
# Provide EITHER AZURE_B2C_TENANT_DOMAIN or AZURE_B2C_TENANT_NAME
AZURE_B2C_TENANT_DOMAIN=
AZURE_B2C_TENANT_NAME=
AZURE_B2C_POLICY=
AZURE_B2C_CLIENT_ID=
AZURE_B2C_CLIENT_SECRET=
AZURE_B2C_REDIRECT_URI=
