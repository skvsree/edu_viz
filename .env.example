# Copy to .env
DATABASE_URL=postgresql+psycopg://srs:srs@db:5432/srs
SECRET_KEY=change-me

# Azure AD B2C (OIDC)
# Provide EITHER AZURE_B2C_TENANT_DOMAIN or AZURE_B2C_TENANT_NAME
AZURE_B2C_TENANT_DOMAIN=
AZURE_B2C_TENANT_NAME=
AZURE_B2C_POLICY=
AZURE_B2C_CLIENT_ID=
AZURE_B2C_CLIENT_SECRET=
AZURE_B2C_REDIRECT_URI=http://localhost:8000/auth/callback
