# Copy to .env
DATABASE_URL=postgresql+psycopg://srs:srs@db:5432/srs
SECRET_KEY=change-me
APP_SESSION_MAX_AGE_SECONDS=3888000
OIDC_STATE_SESSION_MAX_AGE_SECONDS=3888000
SYSTEM_ADMIN_BOOTSTRAP_EMAIL=skv.sree@outlook.com
FOOTER_COPYRIGHT_TEXT=SelViz Software Solutions
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_GENERATION_ENABLED=true

# Microsoft Entra External ID / generic OIDC
# Preferred: set tenant-specific METADATA_URL (or AUTHORITY) for token validation.
# Optionally set AUTHORIZE_AUTHORITY separately if login should start from a different
# authorize host/tenant alias such as https://login.microsoftonline.com/organizations.
MICROSOFT_ENTRA_EXTERNAL_ID_AUTHORITY=
MICROSOFT_ENTRA_EXTERNAL_ID_AUTHORIZE_AUTHORITY=
MICROSOFT_ENTRA_EXTERNAL_ID_METADATA_URL=
MICROSOFT_ENTRA_EXTERNAL_ID_TENANT_ID=
MICROSOFT_ENTRA_EXTERNAL_ID_TENANT_DOMAIN=
MICROSOFT_ENTRA_EXTERNAL_ID_CLIENT_ID=
MICROSOFT_ENTRA_EXTERNAL_ID_CLIENT_SECRET=
MICROSOFT_ENTRA_EXTERNAL_ID_REDIRECT_URI=https://edu.selviz.in/auth/callback
MICROSOFT_ENTRA_EXTERNAL_ID_SCOPES=openid profile email

# Legacy Azure AD B2C compatibility (optional fallback while migrating)
# Provide EITHER AZURE_B2C_TENANT_DOMAIN or AZURE_B2C_TENANT_NAME
AZURE_B2C_TENANT_DOMAIN=
AZURE_B2C_TENANT_NAME=
AZURE_B2C_POLICY=
AZURE_B2C_CLIENT_ID=
AZURE_B2C_CLIENT_SECRET=
AZURE_B2C_REDIRECT_URI=
